// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== ENUMS ====================

enum UserRole {
  USER
  ADMIN
  STAFF
  TREASURY
}

enum EventMode {
  RANGE
  DAYS
}

enum EventCategory {
  EVENTO
  PISCINA_LIBRE
  ACADEMIA
}

enum EventVisibility {
  PUBLIC
  PRIVATE
}

enum EventTicketLayout {
  LIST  // Lista simple de entradas (default)
  PLANS // Cards tipo "planes" (BRONCE/PLATA/ORO) con beneficios y precio tachado
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum TicketStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum EntitlementStatus {
  AVAILABLE
  USED
}

enum ScanResult {
  VALID
  INVALID
  ALREADY_USED
  WRONG_DAY
  WRONG_EVENT
  EXPIRED
}

enum CourtesyStatus {
  PENDING
  CLAIMED
  EXPIRED
}

enum InvoiceStatus {
  PENDING
  PROCESSING
  ISSUED
  FAILED
  FAILED_RETRYABLE
  FAILED_REQUIRES_REVIEW
}

enum DocumentType {
  BOLETA
  FACTURA
}

enum ComplaintBookEntryType {
  RECLAMO
  QUEJA
}

enum ComplaintBookSubjectType {
  PRODUCTO
  SERVICIO
}

enum ComplaintBookStatus {
  RECEIVED
  IN_REVIEW
  RESPONDED
  CLOSED
}

enum OrderType {
  TICKET
  MERCH
}

enum MerchCategory {
  POLERA
  GORRA
  PIN
  OTROS
}

enum MerchZone {
  LIMA
  SUR
  NORTE
  ORIENTE
  GENERICA
}

enum DeliveryMethod {
  PICKUP_EVENT
  SHIPPING_HOME
  PICKUP_OFFICE
}

enum FulfillmentStatus {
  PENDING
  READY
  SHIPPED
  DELIVERED
  PICKED_UP
  CANCELLED
}

// ==================== MODELS ====================

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  passwordHash    String
  role            UserRole  @default(USER)
  emailVerifiedAt DateTime?
  verifyToken     String?
  resetToken      String?
  resetTokenExp   DateTime?
  dni             String?
  phone           String?
  birthDate       DateTime?
  distrito        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  orders           Order[]
  tickets          Ticket[]
  scans            Scan[]           @relation("StaffScans")
  createdEvents    Event[]          @relation("EventCreator")
  courtesyBatches  CourtesyBatch[]
  claimedCourtesy  CourtesyTicket[] @relation("ClaimedBy")
  discountCodes    DiscountCode[]   @relation("DiscountCreator")
  complaintBookEntries ComplaintBookEntry[]
  uploadedAssets   UploadedAsset[]
  billingProfile   UserBillingProfile?

  @@map("users")
}

// Datos de comprobante guardados por el usuario (opt-in "recordar mis datos")
// para autorrellenar el checkout en su próxima compra. Guarda los valores tal
// cual los ingresa en el formulario (dirección sin componer, nombre desglosado).
model UserBillingProfile {
  id                    String       @id @default(cuid())
  userId                String       @unique
  documentType          DocumentType @default(BOLETA)
  buyerDocNumber        String
  buyerName             String?
  buyerAddress          String?
  buyerEmail            String?
  buyerPhone            String?
  buyerUbigeo           String?
  buyerFirstName        String?
  buyerSecondName       String?
  buyerLastNamePaternal String?
  buyerLastNameMaternal String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_billing_profiles")
}

model ComplaintBookEntry {
  id                  String                   @id @default(cuid())
  ticketNumber        String                   @unique
  userId              String?
  type                ComplaintBookEntryType
  subjectType         ComplaintBookSubjectType
  consumerIsMinor     Boolean                  @default(false)
  parentName          String?
  customerName        String
  documentType        String
  documentNumber      String
  email               String
  phone               String?
  address             String
  orderId             String?
  eventName           String?
  subjectDescription  String
  amountClaimed       Decimal?                 @db.Decimal(10, 2)
  detail              String                   @db.Text
  requestDetail       String                   @db.Text
  status              ComplaintBookStatus      @default(RECEIVED)
  responseDetail      String?                  @db.Text
  respondedAt         DateTime?
  emailAcknowledgedAt DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([status])
  @@map("complaint_book_entries")
}

model UploadedAsset {
  id          String   @id @default(cuid())
  provider    String
  kind        String?
  key         String   @unique
  url         String   @unique
  contentType String
  size        Int
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([createdById])
  @@index([provider])
  @@map("uploaded_assets")
}

model Event {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  description String    @db.Text
  location    String
  venue       String
  servilexSucursalCode String @default("01")
  bannerUrl   String?
  startDate   DateTime
  endDate     DateTime
  mode        EventMode @default(RANGE)
  category    EventCategory @default(EVENTO)
  advanceAmount Decimal @default(0) @db.Decimal(10, 2)
  // Solo aplica si category = ACADEMIA. Cantidad de clases por semana del paquete
  // (1..7). Se usa para autocompletar `packageDaysCount` en el creador de entradas.
  academiaWeeklyFrequency Int?
  isPublished Boolean   @default(false)
  visibility  EventVisibility @default(PUBLIC)
  accessToken String?   @unique
  discipline  String?   // e.g., "Natación", "Waterpolo", etc.
  // Cómo se muestran las entradas en la página pública del evento.
  ticketLayout EventTicketLayout @default(LIST)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  createdBy       String
  creator         User            @relation("EventCreator", fields: [createdBy], references: [id])
  eventDays       EventDay[]
  ticketTypes     TicketType[]
  tickets         Ticket[]
  scans           Scan[]
  courtesyBatches CourtesyBatch[]
  discountCodes   DiscountCode[]

  @@index([isPublished, endDate])
  @@index([visibility, isPublished, endDate])
  @@map("events")
}

model EventDay {
  id        String   @id @default(cuid())
  eventId   String
  date      DateTime @db.Date
  openTime  String   // "08:00"
  closeTime String   // "18:00"
  capacity  Int      @default(0) // 0 = unlimited

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, date])
  @@map("event_days")
}

model TicketType {
  id               String   @id @default(cuid())
  eventId          String
  name             String   // "General", "VIP", "Full Day 3 días"
  description      String?
  price            Decimal  @db.Decimal(10, 2)
  currency         String   @default("PEN")
  capacity         Int      @default(0) // 0 = unlimited
  sold             Int      @default(0)
  isPackage        Boolean  @default(false)
  packageDaysCount Int?     // Number of days for package tickets
  // Membresías: cupo de clases por mes. Si está presente, el control de
  // asistencia se reinicia cada mes (use-it-or-lose-it) en vez de usar una
  // bolsa total. Ver scan-helpers.buildMembershipMonthlySummary.
  monthlyClassLimit Int?
  validDays        Json?    // Array of dates ["2024-03-15", "2024-03-16"]
  // Presentación tipo "plan" (layout PLANS del evento)
  originalPrice    Decimal? @db.Decimal(10, 2) // Precio regular para mostrar tachado
  benefits         Json?    // [{ text: string, footnote?: boolean }]
  isFeatured       Boolean  @default(false)    // Destaca el plan (ring + badge)
  highlightLabel   String?  // Badge destacado, ej. "MÁS POPULAR"
  accentColor      String?  // Token de color: "bronze" | "silver" | "gold" | custom
  servilexEnabled        Boolean  @default(false)
  servilexIndicator      String?  @default("AC")
  servilexSucursalCode   String?
  servilexServiceCode    String?
  servilexDisciplineCode String?
  servilexScheduleCode   String?
  servilexPoolCode       String?
  servilexExtraConfig    Json?
  servilexServiceId      String?
  servilexBindingId      String?
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  event           Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  servilexService ServilexService? @relation(fields: [servilexServiceId], references: [id])
  servilexBinding AbioCatalogBinding? @relation(fields: [servilexBindingId], references: [id])
  dateInventories TicketTypeDateInventory[]
  orderItems      OrderItem[]
  tickets         Ticket[]
  courtesyBatches CourtesyBatch[]

  @@index([eventId])
  @@index([isActive])
  @@map("ticket_types")
}

model TicketTypeDateInventory {
  id           String   @id @default(cuid())
  ticketTypeId String
  date         DateTime @db.Date
  capacity     Int      @default(0)
  sold         Int      @default(0)
  isEnabled    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ticketType TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)

  @@unique([ticketTypeId, date])
  @@index([ticketTypeId, date])
  @@map("ticket_type_date_inventories")
}

model Order {
  id               String      @id @default(cuid())
  userId           String
  status           OrderStatus @default(PENDING)
  orderType        OrderType   @default(TICKET)
  totalAmount      Decimal     @db.Decimal(10, 2)
  currency         String      @default("PEN")
  provider         String      @default("IZIPAY")
  providerRef      String?     // Payment reference from provider
  providerOrderNumber String?
  providerTransactionId String?
  providerResponse Json?       // Full response from provider
  paymentSyncAttempts Int      @default(0)
  paymentLastSyncAt DateTime?
  paymentNeedsReview Boolean   @default(false)
  paidAt           DateTime?
  // Merch delivery (null for TICKET orders)
  deliveryMethod    DeliveryMethod?
  pickupEventId     String?
  shippingAddress   String?
  shippingDistrito  String?
  shippingUbigeo    String?
  shippingReference String?
  shippingPhone     String?
  shippingCost      Decimal?           @db.Decimal(10, 2)
  fulfillmentStatus FulfillmentStatus?
  fulfilledAt       DateTime?
  trackingCode      String?
  // Billing data
  documentType     String?     // "BOLETA" or "FACTURA"
  buyerDocType     String?     // "1" = DNI, "6" = RUC
  buyerDocNumber   String?     // DNI (8 digits) or RUC (11 digits)
  buyerName        String?     // Full name or business name
  buyerAddress     String?     // Fiscal address (for FACTURA)
  buyerEmail       String?
  buyerPhone       String?
  buyerUbigeo      String?
  buyerFirstName   String?
  buyerSecondName  String?
  buyerLastNamePaternal String?
  buyerLastNameMaternal String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  // Relations
  user       User        @relation(fields: [userId], references: [id])
  orderItems OrderItem[]
  tickets    Ticket[]
  invoices   Invoice[]

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([createdAt])
  @@index([providerOrderNumber])
  @@index([providerTransactionId])
  @@index([status, provider, paymentNeedsReview, paymentLastSyncAt])
  @@map("orders")
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  ticketTypeId   String?
  merchVariantId String?
  quantity       Int
  unitPrice      Decimal @db.Decimal(10, 2)
  subtotal       Decimal @db.Decimal(10, 2)
  attendeeData   Json?   // [{name, dni}, {name, dni}] for each ticket
  merchSnapshot  Json?   // {productName, size, zone, imageUrl, category} at purchase time

  // Relations
  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType   TicketType?   @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  merchVariant MerchVariant? @relation(fields: [merchVariantId], references: [id])

  @@map("order_items")
}

model Ticket {
  id           String       @id @default(cuid())
  orderId      String
  userId       String
  eventId      String
  ticketTypeId String
  ticketCode   String       @unique // Unique code for QR
  attendeeName String?
  attendeeDni  String?
  status       TicketStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  order         Order                  @relation(fields: [orderId], references: [id])
  user          User                   @relation(fields: [userId], references: [id])
  event         Event                  @relation(fields: [eventId], references: [id])
  ticketType    TicketType             @relation(fields: [ticketTypeId], references: [id])
  entitlements  TicketDayEntitlement[]
  scans         Scan[]
  courtesyInfo  CourtesyTicket?

  @@index([eventId])
  @@index([userId])
  @@index([orderId])
  @@index([status])
  @@map("tickets")
}

model TicketDayEntitlement {
  id       String            @id @default(cuid())
  ticketId String
  date     DateTime          @db.Date
  status   EntitlementStatus @default(AVAILABLE)
  usedAt   DateTime?

  // Relations
  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([ticketId, date])
  @@index([ticketId, status])
  @@map("ticket_day_entitlements")
}

model Scan {
  id        String     @id @default(cuid())
  ticketId  String
  staffId   String
  eventId   String
  date      DateTime   @db.Date
  scannedAt DateTime   @default(now())
  result    ScanResult
  shift     String?
  notes     String?

  // Relations
  ticket Ticket @relation(fields: [ticketId], references: [id])
  staff  User   @relation("StaffScans", fields: [staffId], references: [id])
  event  Event  @relation(fields: [eventId], references: [id])

  @@index([eventId, date])
  @@index([ticketId])
  @@index([ticketId, result])
  @@index([staffId])
  @@index([scannedAt])
  @@map("scans")
}

// ==================== DISCOUNT CODES ====================

enum DiscountType {
  PERCENTAGE  // 20% off
  FIXED       // S/ 10 off
}

model DiscountCode {
  id            String       @id @default(cuid())
  code          String       @unique  // "FDNDA20", "PROMO2026"
  description   String?      // "Descuento para auspiciadores"
  type          DiscountType @default(PERCENTAGE)
  value         Decimal      @db.Decimal(10, 2) // 20 for 20%, or 10 for S/10
  eventId       String?      // null = applies to all events
  minPurchase   Decimal?     @db.Decimal(10, 2) // Minimum purchase amount
  maxUses       Int?         // null = unlimited
  usedCount     Int          @default(0)
  maxUsesPerUser Int?        @default(1)  // How many times same user can use
  validFrom     DateTime     @default(now())
  validUntil    DateTime?
  isActive      Boolean      @default(true)
  createdBy     String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Relations
  event   Event?        @relation(fields: [eventId], references: [id])
  creator User          @relation("DiscountCreator", fields: [createdBy], references: [id])
  usages  DiscountUsage[]

  @@map("discount_codes")
}

model DiscountUsage {
  id             String   @id @default(cuid())
  discountCodeId String
  orderId        String
  userId         String
  amountSaved    Decimal  @db.Decimal(10, 2)
  usedAt         DateTime @default(now())

  // Relations
  discountCode DiscountCode @relation(fields: [discountCodeId], references: [id])

  @@unique([discountCodeId, orderId])
  @@map("discount_usages")
}

// ==================== COURTESY SYSTEM ====================

model CourtesyBatch {
  id           String   @id @default(cuid())
  eventId      String
  ticketTypeId String
  createdBy    String
  quantity     Int
  reason       String?
  createdAt    DateTime @default(now())

  // Relations
  event           Event            @relation(fields: [eventId], references: [id])
  ticketType      TicketType       @relation(fields: [ticketTypeId], references: [id])
  creator         User             @relation(fields: [createdBy], references: [id])
  courtesyTickets CourtesyTicket[]

  @@map("courtesy_batches")
}

model CourtesyTicket {
  id              String         @id @default(cuid())
  ticketId        String?        @unique
  batchId         String
  claimCode       String         @unique
  claimedByUserId String?
  status          CourtesyStatus @default(PENDING)
  expiresAt       DateTime?
  claimedAt       DateTime?
  
  // Pre-assigned attendee data (optional)
  assignedName    String?
  assignedDni     String?

  // Relations
  ticket    Ticket?        @relation(fields: [ticketId], references: [id])
  batch     CourtesyBatch  @relation(fields: [batchId], references: [id])
  claimedBy User?          @relation("ClaimedBy", fields: [claimedByUserId], references: [id])

  @@map("courtesy_tickets")
}

model ServilexService {
  id          String       @id @default(cuid())
  codigo      String       @unique  // "LNAT12", "TPOL08", etc.
  indicador   String       // "AC"
  disciplina  String       // "NATACION", "CLAVADOS", etc.
  sede        String       // "LIMA", "VMT", "TRUJILLO", "HUANCHACO"
  clases      Int?         // 4, 8, 12, 20, null para BECA/REINTEGRO
  descripcion String       // "NATACION 12 clases - LIMA"
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  ticketTypes   TicketType[]
  merchProducts MerchProduct[]

  @@index([indicador])
  @@index([isActive])
  @@map("servilex_services")
}

model AbioCatalogService {
  id                  String   @id @default(cuid())
  codigoEmp           String
  sucursalCodigo      String
  servicioCodigo      String
  servicioDescripcion String
  isActive            Boolean  @default(true)
  rawPayload          Json?
  syncedAt            DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([codigoEmp, sucursalCodigo, servicioCodigo])
  @@index([codigoEmp, sucursalCodigo, isActive])
  @@index([servicioCodigo])
  @@map("abio_catalog_services")
}

model AbioCatalogDiscipline {
  id               String   @id @default(cuid())
  codigoEmp        String
  disciplinaCodigo String
  disciplinaNombre String
  isActive         Boolean  @default(true)
  rawPayload       Json?
  syncedAt         DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([codigoEmp, disciplinaCodigo])
  @@index([codigoEmp, isActive])
  @@index([disciplinaCodigo])
  @@map("abio_catalog_disciplines")
}

model AbioCatalogSchedule {
  id               String   @id @default(cuid())
  codigoEmp        String
  disciplinaCodigo String
  horarioCodigo    String
  diaDescripcion   String
  lunes            String?
  martes           String?
  miercoles        String?
  jueves           String?
  viernes          String?
  sabado           String?
  domingo          String?
  horaInicio       String?
  horaFin          String?
  duracionHoras    Decimal? @db.Decimal(10, 2)
  isActive         Boolean  @default(true)
  rawPayload       Json?
  syncedAt         DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([codigoEmp, disciplinaCodigo, horarioCodigo])
  @@index([codigoEmp, disciplinaCodigo, isActive])
  @@index([horarioCodigo])
  @@map("abio_catalog_schedules")
}

model AbioCatalogBinding {
  id               String   @id @default(cuid())
  codigoEmp        String
  sucursalCodigo   String
  servicioCodigo   String
  disciplinaCodigo String
  piscinaCodigo    String
  horarioCodigo    String
  numeroCupos      Int
  isActive         Boolean  @default(true)
  source           String   @default("IMPORT")
  rawPayload       Json?
  syncedAt         DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  ticketTypes      TicketType[]

  @@unique([codigoEmp, sucursalCodigo, servicioCodigo, disciplinaCodigo, piscinaCodigo, horarioCodigo])
  @@index([codigoEmp, sucursalCodigo, servicioCodigo, isActive])
  @@index([disciplinaCodigo, horarioCodigo])
  @@map("abio_catalog_bindings")
}

model AbioCatalogSyncRun {
  id               String   @id @default(cuid())
  resource         String
  status           String
  requestPayload   Json?
  responsePayload  Json?
  importedCount    Int      @default(0)
  deactivatedCount Int      @default(0)
  errorMessage     String?
  startedAt        DateTime @default(now())
  finishedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([resource, startedAt])
  @@index([status, startedAt])
  @@map("abio_catalog_sync_runs")
}

model Invoice {
  id               String        @id @default(cuid())
  orderId          String
  servilexGroupKey String        @default("legacy")
  status           InvoiceStatus @default(PENDING)
  documentType     DocumentType  @default(BOLETA)
  servilexIndicator String?
  servilexSucursalCode String?
  servilexGroupType String?
  servilexGroupLabel String?
  assignedTotal    Decimal       @default(0) @db.Decimal(10, 2)
  alumnoSnapshot   Json?
  servilexPayloadSnapshot Json?
  invoiceNumber    String?       // SUNAT serie-correlativo (e.g. B001-00000001)
  // Buyer fiscal data
  buyerDocType     String?       // "1" = DNI, "6" = RUC
  buyerDocNumber   String?       // DNI (8 digits) or RUC (11 digits)
  buyerName        String?       // Full name or business name (razón social)
  buyerAddress     String?       // Fiscal address (for FACTURA)
  buyerEmail       String?
  buyerPhone       String?
  buyerUbigeo      String?
  buyerFirstName   String?
  buyerSecondName  String?
  buyerLastNamePaternal String?
  buyerLastNameMaternal String?
  // Provider integration
  traceId          String?       @unique
  requestPayload   String?       @db.Text
  requestSignature String?
  httpStatus       Int?
  reciboHash       String?
  providerResponse Json?         // Response from ABIO/Servilex
  pdfUrl           String?       // URL of the issued document PDF
  sentToProvider   Boolean       @default(false)
  retryCount       Int           @default(0)
  lastError        String?
  sentAt           DateTime?
  issuedAt         DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  order Order @relation(fields: [orderId], references: [id])

  @@unique([orderId, servilexGroupKey])
  @@index([orderId])
  @@index([status])
  @@map("invoices")
}

enum TicketIssuanceOutcome {
  OK
  NO_ENTITLEMENT
  TICKET_NOT_ACTIVE
  TICKET_NOT_FOUND
  UNAUTHORIZED
  QR_GENERATION_ERROR
  INTERNAL_ERROR
}

model TicketIssuanceLog {
  id        String                @id @default(cuid())
  ticketId  String?
  userId    String?
  eventId   String?
  outcome   TicketIssuanceOutcome
  reason    String?               @db.Text
  qrDate    String?
  qrShift   String?
  requestedDate String?
  userAgent String?               @db.Text
  ipAddress String?
  createdAt DateTime              @default(now())

  @@index([ticketId, createdAt])
  @@index([outcome, createdAt])
  @@index([createdAt])
  @@map("ticket_issuance_logs")
}

// ==================== MERCH ====================

model MerchProduct {
  id                  String        @id @default(cuid())
  slug                String        @unique
  name                String
  description         String?       @db.Text
  category            MerchCategory
  zone                MerchZone     @default(GENERICA)
  etapa               String?
  price               Decimal       @db.Decimal(10, 2)
  currency            String        @default("PEN")
  imageUrl            String?
  imageUrls           Json?
  hasSizes            Boolean       @default(false)
  availableSizes      Json?
  isActive            Boolean       @default(true)
  sortOrder           Int           @default(0)
  servilexServiceId   String?       // deprecated: usar servilexServiceCode (codigo del catalogo ABIO)
  servilexServiceCode String?       // codigo ABIO (AbioCatalogService.servicioCodigo) para emitir boleta OS
  servilexSucursalCode String?      // sucursal ABIO para el comprobante (default env SERVILEX_SUCURSAL si null)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  servilexService ServilexService? @relation(fields: [servilexServiceId], references: [id])
  variants        MerchVariant[]

  @@index([category, zone, isActive])
  @@index([isActive, sortOrder])
  @@map("merch_products")
}

model MerchVariant {
  id        String   @id @default(cuid())
  productId String
  size      String?
  sku       String   @unique
  stock     Int      @default(0)
  reserved  Int      @default(0)
  sold      Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product    MerchProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@unique([productId, size])
  @@index([productId, isActive])
  @@map("merch_variants")
}
