# Caddyfile - Reverse Proxy con SSL automático
# Reemplaza "tickets.fdnda.org.pe" con tu dominio real

tickets.fdnda.org.pe {
    # Proxy a la app Next.js
    reverse_proxy app:3000

    # Compresión
    encode gzip zstd

    # Logs
    log {
        output file /data/access.log {
            roll_size 10MB
            roll_keep 5
        }
    }

    # Headers de seguridad adicionales
    header {
        # HSTS (Next.js ya lo agrega, pero reforzamos)
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        # Prevenir clickjacking
        X-Frame-Options "SAMEORIGIN"
        # Prevenir MIME sniffing
        X-Content-Type-Options "nosniff"
        # Remove server header
        -Server
    }

    # Cache para assets estáticos
    @static {
        path /_next/static/* /favicon.ico /icon.png *.svg *.png *.jpg *.webp
    }
    header @static Cache-Control "public, max-age=31536000, immutable"
}

# Redirect www -> non-www (si usas www)
www.tickets.fdnda.org.pe {
    redir https://tickets.fdnda.org.pe{uri} permanent
}
