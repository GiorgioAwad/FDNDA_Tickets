# ========================================
# fdnda-tickets Production Environment
# ========================================
# Copy this file to .env.production on the VPS and complete all real values.

# Database (Neon recommended for production)
DATABASE_URL=postgresql://USER:PASSWORD@YOUR-NEON-HOST/dbname?sslmode=require
DIRECT_URL=
DB_POOL_MAX=20
DB_POOL_MIN=5

# Optional local-db compatibility profile only
DB_USER=fdnda
DB_PASSWORD=CHANGEME_use_a_strong_password_here
DB_NAME=fdnda_tickets

# App images / runtime
APP_IMAGE=ghcr.io/giorgioawad/fdnda-tickets-app:latest
TOOLS_IMAGE=ghcr.io/giorgioawad/fdnda-tickets-tools:latest
NEXT_PUBLIC_APP_URL=https://ticketingfdnda.pe
NEXT_PUBLIC_APP_NAME=Ticketing FDNDA
NEXT_PUBLIC_PAYMENTS_MODE=mock
NEXT_PUBLIC_LEGAL_ENTITY_NAME="Federacion Deportiva Nacional de Deportes Acuaticos del Peru"
NEXT_PUBLIC_LEGAL_COMMERCIAL_NAME="Ticketing FDNDA"
NEXT_PUBLIC_LEGAL_RUC=
NEXT_PUBLIC_LEGAL_ADDRESS="Jr. Nazca Cdra. 6 s/n Lima 11, Peru"
NEXT_PUBLIC_LEGAL_PHONE="+51 941 632 535"
NEXT_PUBLIC_LEGAL_EMAIL="ticketing@fdnda.org"
NEXT_PUBLIC_PRIVACY_EMAIL="ticketing@fdnda.org"
NEXT_PUBLIC_COMPLAINTS_EMAIL="ticketing@fdnda.org"
NEXT_PUBLIC_DATA_BANK_NAME=
NEXT_PUBLIC_DATA_BANK_CODE=

# NextAuth
NEXTAUTH_SECRET=CHANGEME_generate_with_openssl_rand_base64_32
NEXTAUTH_URL=https://ticketingfdnda.pe
AUTH_TRUST_HOST=true

# Email
RESEND_API_KEY=CHANGEME_re_xxxxx
EMAIL_FROM="Ticketing FDNDA <tickets@fdnda.org.pe>"
EMAIL_PROVIDER=resend
USE_EMAIL_QUEUE=true
PRIVACY_EMAIL="ticketing@fdnda.org"
COMPLAINTS_EMAIL="ticketing@fdnda.org"

# Izipay
IZIPAY_MERCHANT_CODE=CHANGEME
IZIPAY_API_KEY=CHANGEME
IZIPAY_HASH_KEY=CHANGEME
IZIPAY_PUBLIC_KEY=CHANGEME
IZIPAY_ENDPOINT=https://sandbox-api-pw.izipay.pe
IZIPAY_SEARCH_TRANSACTION_URL=
IZIPAY_QUERY_LANGUAGE=ESP
IZIPAY_MODE=redirect
NEXT_PUBLIC_IZIPAY_MODE=redirect
NEXT_PUBLIC_IZIPAY_SCRIPT_URL=https://sandbox-checkout.izipay.pe/payments/v1/js/index.js
NEXT_PUBLIC_IZIPAY_PUBLIC_KEY=
IZIPAY_CHECKOUT_URL=
PAYMENTS_MODE=mock

# Servilex
SERVILEX_ENABLED=false
SERVILEX_ENDPOINT=https://abio-pse.ue.r.appspot.com/fpdn/invoice
SERVILEX_TOKEN=CHANGEME
SERVILEX_EMPRESA=FPDN
SERVILEX_USUARIO=CHANGEME
SERVILEX_PASSWORD=CHANGEME
SERVILEX_TERMINAL=cajaweb
SERVILEX_CODIGO_EMP=001
SERVILEX_SUCURSAL=01
ABIO_CATALOG_SERVICES_ENDPOINT=https://abio-pse.ue.r.appspot.com/fpdn/servicio
ABIO_CATALOG_DISCIPLINES_ENDPOINT=https://abio-pse.ue.r.appspot.com/fpdn/disciplina
ABIO_CATALOG_SCHEDULES_ENDPOINT=https://abio-pse.ue.r.appspot.com/fpdn/horario
ABIO_CATALOG_SUCURSALES=01
SERVILEX_SERIE_BOLETA=B001
SERVILEX_SERIE_FACTURA=F001
SERVILEX_FORMA_PAGO=006
SERVILEX_TARJETA_TIPO=VISA
SERVILEX_TARJETA_PROCEDENCIA=N
SERVILEX_CONDICION_PAGO=01
SERVILEX_TIPO_TRIBUTO=9998
SERVILEX_REFERENCIA=-
SERVILEX_TIPO_REGISTRO=2
SERVILEX_EJECUTIVO=
SERVILEX_MAX_RETRIES=3

# QR / Cron
QR_SECRET=CHANGEME_generate_with_openssl_rand_hex_32
CRON_SECRET=CHANGEME_generate_with_openssl_rand_hex_32

# Redis (Upstash paid recommended)
UPSTASH_REDIS_REST_URL=CHANGEME
UPSTASH_REDIS_REST_TOKEN=CHANGEME

# Worker
WORKER_EMAIL_INTERVAL_MS=60000
WORKER_INVOICE_INTERVAL_MS=120000
WORKER_EXPIRE_ORDERS_INTERVAL_MS=300000
WORKER_EMAIL_BATCH_SIZE=20
WORKER_INVOICE_BATCH_SIZE=10

# Object storage (Cloudflare R2 recommended)
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=CHANGEME
R2_ACCESS_KEY_ID=CHANGEME
R2_SECRET_ACCESS_KEY=CHANGEME
R2_BUCKET=fdnda-assets
R2_PUBLIC_BASE_URL=https://assets.ticketingfdnda.pe

# Compatibility for legacy local uploads / optional blob usage
UPLOAD_DIR=./public/uploads
BLOB_READ_WRITE_TOKEN=

# Observability
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
